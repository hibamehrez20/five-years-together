{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase-database.rules.json",
      "**/.*",
      "**/node_modules/**",
      "**/tools/**",
      "README.md",
      "generate-jar-messages.js"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  }
}
