{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase-database.rules.json",
      "**/.*",
      "**/node_modules/**",
      "**/tools/**",
      "README.md",
      "generate-jar-messages.js",
      "functions/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "firebase-messaging-sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          },
          {
            "key": "Service-Worker-Allowed",
            "value": "/"
          }
        ]
      }
    ]
  },
  "database": {
    "rules": "firebase-database.rules.json"
  },
  "functions": {
    "source": "functions"
  }
}
